{
    "CallerReference": "ayan-portfolio-2025-cf",
    "Comment": "Ayan Sadhukhan Portfolio",
    "DefaultCacheBehavior": {
        "TargetOriginId": "S3-ayan-portfolio-2025",
        "ViewerProtocolPolicy": "redirect-to-https",
        "TrustedSigners": {
            "Enabled": false,
            "Quantity": 0
        },
        "ForwardedValues": {
            "QueryString": false,
            "Cookies": {
                "Forward": "none"
            }
        },
        "MinTTL": 0,
